# -------------------------------------------------------
# Forum AI Notetaker — environment configuration
# Copy this file to .env before running the app and fill in the values.
# -------------------------------------------------------

# Required. Used to sign and verify JWT tokens for authentication.
# Any string works for local dev — do not change it after users have
# registered or their tokens will be invalidated. In production this
# placeholder is rejected at boot; set a real random value on Railway
# (openssl rand -hex 32).
JWT_SECRET_KEY=cs162-forum-ai-notetaker-2026

# Optional. Used to generate structured AI notes from transcripts.
# If left blank, the app falls back to a basic summary extracted
# from the transcript text — no Groq account needed.
GROQ_API_KEY=your_key_here

# Optional. How long login tokens stay valid (in hours). Defaults to 24.
JWT_EXPIRY_HOURS=24

# -------------------------------------------------------
# Production / Railway deployment settings
# These are only required when RAILWAY_ENVIRONMENT is set (i.e. on
# Railway). Locally they can be ignored — safe defaults kick in.
# -------------------------------------------------------

# Gate for professor self-registration. Without this, anyone hitting the
# public URL could create a professor account and burn Groq quota.
# Generate with: openssl rand -hex 16
PROFESSOR_REGISTRATION_SECRET=CHANGE_ME

# Port the Flask/gunicorn server binds to. Railway injects this automatically.
PORT=5000

# Absolute path to the SQLite database file. Point at a mounted volume in
# production so data survives redeploys.
DATABASE_PATH=/app/data/forum_ai_notetaker.sqlite3

# Absolute path to uploaded recordings. Point at a mounted volume in prod.
UPLOAD_FOLDER=/app/backend/uploads

# Comma-separated list of allowed frontend origins. Use * for local dev.
# In production set this to the deployed frontend URL, e.g.
# https://frontend-production-xxxx.up.railway.app
CORS_ORIGINS=*
